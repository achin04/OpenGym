# Copy this file to .env for local development.
# Never commit real secrets in .env.

# Used by Prisma to connect to the local PostgreSQL development database.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/opengym_dev?schema=public"

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"

# Comma-separated email addresses allowed to access admin operations.
ADMIN_EMAILS="admin@example.com"
